# Anthropic — extração estruturada de orçamentos (Claude API)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI — transcrição de áudio via Whisper
OPENAI_API_KEY=

# Google OAuth — autenticação via NextAuth (qualquer conta Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Slides — ID do template Cath no Drive (<!-- CONFIRMAR COM LUCAS -->)
GOOGLE_SLIDES_TEMPLATE_ID=

# Google Drive — ID da pasta onde os PDFs exportados serão salvos
GOOGLE_DRIVE_OUTPUT_FOLDER_ID=

# NextAuth — segredo mínimo 32 chars + URL base da aplicação
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
